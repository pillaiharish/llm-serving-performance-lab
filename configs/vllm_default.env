# Day 1 local vLLM server config.
# Usage:
#   source configs/vllm_default.env

export MODEL_NAME=models/Qwen/Qwen2.5-0.5B-Instruct
export HOST=0.0.0.0
export PORT=8000
export MAX_MODEL_LEN=4096
export GPU_MEMORY_UTILIZATION=0.85

# Workaround for RTX 50-series / SM 12.x FlashInfer sampler startup issue.
export VLLM_USE_FLASHINFER_SAMPLER=0

# Optional local cache location. Uncomment if needed.
# export HF_HOME=/data/hf_cache