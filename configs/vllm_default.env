# Day 1 local vLLM server config.
# Copy to .env if needed to edit locally:
#   cp configs/vllm_default.env .env

MODEL_NAME=models/Qwen/Qwen2.5-0.5B-Instruct
HOST=0.0.0.0
PORT=8000
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.85
VLLM_USE_FLASHINFER_SAMPLER=0

# Optional local cache location. Uncomment if need to avoid filling home dir.
# HF_HOME=/data/hf_cache